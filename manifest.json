{
  "manifest_version": 3,
  "name": "MatchTube",
  "author": "Jan Nosek",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "version": "1.0.0",
  "description": "Find matches for the video you are watching",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://*.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  }
}
