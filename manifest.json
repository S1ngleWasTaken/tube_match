{
  "manifest_version": 3,
  "name": "WatchMatch",
  "version": "1.0.0",
  "description": "Find matches for the video you are watching",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
